#!/usr/bin/env python3
"""
Multi-provider LLM cost tracker CLI.

Queries the ai_consultant_audit table for LLM_CALL events, groups by
provider and model, and prints a cost table.

Usage:
    btc-spend                  # last 30 days
    btc-spend --month          # since start of current month
    btc-spend --week           # last 7 days
    btc-spend --day            # last 24 hours
    btc-spend --days 90        # last 90 days
"""

from __future__ import annotations

import argparse
import os
import sys
from datetime import datetime, timedelta, timezone

sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", "src"))

from ai_consultant.cost_tracker import CostTracker, ProviderCost  # noqa: E402


HEADER = f"{'Provider':<16} {'Model':<32} {'Calls':>7} {'Input Tok':>12} {'Output Tok':>12} {'Est. Cost':>12}"
SEP = "-" * len(HEADER)
FMT = "{provider:<16} {model:<32} {calls:>7,} {input_tokens:>12,} {output_tokens:>12,} ${estimated_cost:>11.4f}"


def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Multi-provider LLM cost tracker",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="Without a flag, defaults to a 30-day window.",
    )
    group = parser.add_mutually_exclusive_group()
    group.add_argument("--month", action="store_true", help="Since start of current month (UTC)")
    group.add_argument("--week", action="store_true", help="Last 7 days")
    group.add_argument("--day", action="store_true", help="Last 24 hours")
    group.add_argument("--days", type=int, default=None, help="Last N days (default: 30)")
    return parser.parse_args(argv)


def resolve_since(args: argparse.Namespace) -> datetime:
    now = datetime.now(timezone.utc)
    if args.month:
        return now.replace(day=1, hour=0, minute=0, second=0, microsecond=0)
    if args.week:
        return now - timedelta(days=7)
    if args.day:
        return now - timedelta(days=1)
    if args.days is not None:
        return now - timedelta(days=args.days)
    return now - timedelta(days=30)


def format_row(row: ProviderCost) -> str:
    return FMT.format(
        provider=row.provider,
        model=row.model,
        calls=row.calls,
        input_tokens=row.input_tokens,
        output_tokens=row.output_tokens,
        estimated_cost=row.estimated_cost,
    )


def main(argv: list[str] | None = None) -> None:
    args = parse_args(argv)
    since = resolve_since(args)

    tracker = CostTracker()
    try:
        rows = tracker.query_costs(since=since)
    except Exception as exc:
        print(f"Error querying audit log: {exc}", file=sys.stderr)
        sys.exit(1)
    finally:
        tracker.close()

    if not rows:
        print(f"No LLM_CALL events found since {since.strftime('%Y-%m-%d %H:%M UTC')}")
        return

    print(f"\nCosts since {since.strftime('%Y-%m-%d %H:%M UTC')}\n")
    print(HEADER)
    print(SEP)

    for row in rows:
        print(format_row(row))

    totals = tracker.compute_totals(rows)
    print(SEP)
    print(format_row(totals))
    print()


if __name__ == "__main__":
    main()
