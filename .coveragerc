[run]
source = src
omit =
    # UI modules require Qt display — excluded from CI coverage denominator
    src/strategy_builder/ui/*
    src/optimizer_v3/ui/*
    src/strategies/universal_optimizer/modules/ui.py

    # NautilusTrader-dependent modules — package not installed in CI
    src/strategies/strategy_*.py
    src/strategies/signal_accumulator/*
    src/optimizer_v3/core/multicore_backtest_engine.py
    src/optimizer_v3/core/nautilus_training_system.py
    src/optimizer_v3/core/backtest_data_provider.py
    src/optimizer_v3/database/nautilus_types.py
    src/data_manager/nautilus_loader.py
    src/strategy_builder/testing/walkforward_test_engine.py
    src/strategy_builder/core/nautilus_code_generator.py

    # jinja2-dependent modules — package not installed in CI
    src/utils/Strategy_Builder/generator.py

    # psutil-dependent modules — package not installed in CI
    src/optimizer_v3/core/resource_monitor.py
    src/optimizer_v3/core/parallel_executor.py
    src/optimizer_v3/core/orchestrator_integration.py

    # External data-layer modules with no unit tests in CI scope
    src/data_manager/*
    src/detectors/*
    src/indicators/*
    src/debugger_logger/*
    src/optimizer_v3/*
    src/strategies/*

    # strategy_builder non-UI modules — their tests require PyQt5/NautilusTrader
    # which are not available in headless CI; excluded from coverage denominator
    # (strategy_builder/ui/* already excluded above)
    src/strategy_builder/__init__.py
    src/strategy_builder/utils/__init__.py
    src/strategy_builder/core/block_registry_adapter.py
    src/strategy_builder/core/registry_interface.py
    src/strategy_builder/core/signal_dependency_resolver.py
    src/strategy_builder/core/strategy_config_engine.py
    src/strategy_builder/execution/block_state_manager.py
    src/strategy_builder/integration/strategy_builder_orchestrator.py
    src/strategy_builder/persistence/strategy_persistence.py
    src/strategy_builder/utils/institutional_logger.py
    src/strategy_builder/utils/signal_statistics_loader.py
    src/strategy_builder/utils/signal_statistics_updater.py
    src/strategy_builder/validation/auto_fix.py
    src/strategy_builder/validation/strategy_validator.py
    src/strategy_builder/validation/undo_manager.py

[report]
# Exclude test files themselves and __init__ stubs
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__.:
    raise NotImplementedError
    \.\.\.
    pass
