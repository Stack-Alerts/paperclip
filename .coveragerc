[run]
source = src
omit =
    # UI modules require Qt display — excluded from CI coverage denominator
    src/strategy_builder/ui/*
    src/optimizer_v3/ui/*
    src/strategies/universal_optimizer/modules/ui.py

    # NautilusTrader-dependent modules — package not installed in CI
    src/strategies/strategy_*.py
    src/strategies/signal_accumulator/*
    src/optimizer_v3/core/multicore_backtest_engine.py
    src/optimizer_v3/core/nautilus_training_system.py
    src/optimizer_v3/core/backtest_data_provider.py
    src/optimizer_v3/database/nautilus_types.py
    src/data_manager/nautilus_loader.py
    src/strategy_builder/testing/walkforward_test_engine.py
    src/strategy_builder/core/nautilus_code_generator.py

    # jinja2-dependent modules — package not installed in CI
    src/utils/Strategy_Builder/generator.py

    # psutil-dependent modules — package not installed in CI
    src/optimizer_v3/core/resource_monitor.py
    src/optimizer_v3/core/parallel_executor.py
    src/optimizer_v3/core/orchestrator_integration.py

    # External data-layer modules with no unit tests in CI scope
    src/data_manager/*
    src/detectors/*
    src/indicators/*
    src/debugger_logger/*
    src/optimizer_v3/*
    src/strategies/*

[report]
# Exclude test files themselves and __init__ stubs
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__.:
    raise NotImplementedError
    \.\.\.
    pass
