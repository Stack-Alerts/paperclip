# BTC Engine v3 - Environment Configuration
# Copy this file to .env and fill in your credentials
# NEVER commit .env to git!

# ============================================================================
# LAKEAPI CREDENTIALS (REQUIRED)
# ============================================================================
# Get your credentials from: https://cryptolake.com
# These are used to download market data from LakeAPI S3

LAKEAPI_KEY=your_access_key_here
LAKEAPI_SECRET=your_secret_key_here
LAKEAPI_REGION=eu-west-1

# ============================================================================
# LAKEAPI USAGE LIMITS
# ============================================================================
# Monthly transfer limit in GB (default: 300GB for standard plan)
LAKEAPI_LIMIT_GB=300

# ============================================================================
# MULTICORE PROCESSING
# ============================================================================
# Number of cores to use for parallel processing
# Leave empty to auto-detect (uses total_cores - 2)
# MULTICORE_WORKERS=28

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================
# Memory limit per worker in GB
# MEMORY_LIMIT_GB=16

# ============================================================================
# MONITORING & ALERTS
# ============================================================================
# Enable usage alerts
# ENABLE_ALERTS=true

# Email for alerts (optional)
# ALERT_EMAIL=your@email.com

# ============================================================================
# LOGGING
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# ============================================================================
# POSTGRESQL DATABASE (OPTIMIZER V3)
# ============================================================================
# PostgreSQL connection settings for Optimizer v3
# Install PostgreSQL: sudo apt-get install postgresql postgresql-contrib

# Database connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=optimizer_v3
POSTGRES_USER=optimizer_admin
POSTGRES_PASSWORD=secure_password_change_me

# SSL Configuration (production)
POSTGRES_SSL=false
POSTGRES_SSL_CERT_PATH=/path/to/server.crt
POSTGRES_SSL_KEY_PATH=/path/to/server.key

# Connection Pool Settings
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_TIMEOUT=30
POSTGRES_POOL_RECYCLE=3600

# Performance Settings (optional - PostgreSQL defaults are usually fine)
# POSTGRES_SHARED_BUFFERS=1GB
# POSTGRES_WORK_MEM=32MB
# POSTGRES_MAINTENANCE_WORK_MEM=256MB
# POSTGRES_EFFECTIVE_CACHE_SIZE=3GB
# POSTGRES_WAL_BUFFERS=16MB
# POSTGRES_CHECKPOINT_TIMEOUT=10min
# POSTGRES_RANDOM_PAGE_COST=1.1
# POSTGRES_EFFECTIVE_IO_CONCURRENCY=200

# Monitoring Settings
POSTGRES_LOG_MIN_DURATION=1000
POSTGRES_LOG_CONNECTIONS=false
POSTGRES_LOG_DISCONNECTIONS=false

# Backup Settings
POSTGRES_BACKUP_PATH=/home/sirrus/backups/optimizer_v3
POSTGRES_BACKUP_RETENTION_DAYS=30
POSTGRES_BACKUP_COMPRESSION=true

# ============================================================================
# SECURITY NOTES
# ============================================================================
# NEVER commit .env to git!
# .env is already in .gitignore
# Use .env.example for documentation only
# Keep credentials secure
