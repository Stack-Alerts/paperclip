RESEARCH PATTERN DETECTION:
def check_m_pattern(self, bars):
    '''Check if last 3 bars form M pattern'''
    if len(bars) < 3:
        return False
    # Down-Up-Down
    down_1 = bars[-3].close > bars[-2].close
    up = bars[-2].close < bars[-1].close
    down_2_pending = True # Wait for next bar
    return down_1 and up

RESEARCH STORAGE:
self.patterns_found = []

def on_bar(self, bar: Bar):
    if self.check_m_pattern(self.bars):
        self.patterns_found.append({
            'timestamp': bar.ts_event,
            'price': bar.close,
            'high': bar.high,
            'low': bar.low,
        })
"""

