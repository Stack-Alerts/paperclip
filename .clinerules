COMMON_PATTERNS = """
CREATING AN ORDER:
from nautilus_trader.model.orders import MarketOrder
from nautilus_trader.model.enums import OrderSide

order = MarketOrder(
    instrument_id=self.instrument_id,
    client_order_id=self.order_factory.client_order_id(),
    order_side=OrderSide.BUY,
    quantity=Quantity(0.1),
    time_in_force=TimeInForce.IOC,
)
self.submit_order(order)

CHECKING POSITION:
position = self.portfolio.net_position(self.instrument)
if position is None:
    size = 0
else:
    size = position.quantity

CALCULATING PnL:
unrealized = self.portfolio.unrealized_pnl(self.instrument)
realized = self.portfolio.realized_pnl(self.instrument)

SUBSCRIBING TO DATA:
bar_type = BarType(self.instrument_id, BarAggregation.MINUTE, 15)
self.subscribe_bars(bar_type)

LOGGING:
self.log.info(f"Buying {quantity} BTC at ${price}")
self.log.warning(f"Drawdown: {drawdown:.2%}")
self.log.error(f"Order rejected: {reason}")

RESEARCH PATTERN DETECTION:
def check_m_pattern(self, bars):
    '''Check if last 3 bars form M pattern'''
    if len(bars) < 3:
        return False
    # Down-Up-Down
    down_1 = bars[-3].close > bars[-2].close
    up = bars[-2].close < bars[-1].close
    down_2_pending = True # Wait for next bar
    return down_1 and up

RESEARCH STORAGE:
self.patterns_found = []

def on_bar(self, bar: Bar):
    if self.check_m_pattern(self.bars):
        self.patterns_found.append({
            'timestamp': bar.ts_event,
            'price': bar.close,
            'high': bar.high,
            'low': bar.low,
        })
"""

