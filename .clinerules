============================================================================
CORE TYPES (MUST USE THESE)
============================================================================
TYPES = """
Quantity: Order size/volume
  Usage: Quantity(0.1)
  Never: float
  Docs: https://nautilustrader.io/docs/latest/api/types/

Price: Bid/ask/last prices
  Usage: Price('45000.50')
  Never: float or Decimal
  Docs: https://nautilustrader.io/docs/latest/api/types/

Money: Monetary amounts (PnL, fees, balance)
  Usage: Money('500.75', USD)
  Always: include currency
  Docs: https://nautilustrader.io/docs/latest/api/types/

InstrumentId: Unique instrument identifier
  Usage: InstrumentId(Symbol('BTC'), Venue('CCXT'))
  Never: strings like 'BTC/USDT'
  Docs: https://nautilustrader.io/docs/latest/api/model/

BarType: Bar specification
  Usage: BarType(instrument_id, BarAggregation.MINUTE, 15)
  Docs: https://nautilustrader.io/docs/latest/api/model/
"""

============================================================================
CRITICAL ENUMS (USE THESE ONLY)
============================================================================
ENUMS = """
OrderSide: BUY, SELL
OrderType: MARKET, LIMIT, STOP_MARKET, STOP_LIMIT
TimeInForce: GTC, IOC, FOK, DAY
OrderStatus: SUBMITTED, ACCEPTED, FILLED, CANCELED, REJECTED
BarAggregation: MINUTE, HOUR, DAY
PositionStatus: OPENED, CLOSED, CLOSING
AccountStatus: READY, ACTIVE, CLOSING

IMPORTANT:
✓ Always import from nautilus_trader
✓ Never use strings like "BUY" - use OrderSide.BUY
✓ Always use module.ENUM format

Example (CORRECT):
  order = MarketOrder(..., order_side=OrderSide.BUY)

Example (WRONG):
  order = MarketOrder(..., order_side="BUY")

Docs: https://nautilustrader.io/docs/latest/api/enums/
"""

