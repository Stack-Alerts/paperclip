ENUMS = """
OrderSide: BUY, SELL
OrderType: MARKET, LIMIT, STOP_MARKET, STOP_LIMIT
TimeInForce: GTC, IOC, FOK, DAY
OrderStatus: SUBMITTED, ACCEPTED, FILLED, CANCELED, REJECTED
