============================================================================
RESEARCH STRATEGY TEMPLATE
============================================================================
RESEARCH_STRATEGY_TEMPLATE = '''
from nautilus_trader.trading.strategy import Strategy
from nautilus_trader.core.data import Bar
from nautilus_trader.model.enums import BarAggregation
from nautilus_trader.model.identifiers import InstrumentId
from nautilus_trader.model.types import Price, Quantity
import pandas as pd
from datetime import datetime

class PatternDiscoveryStrategy(Strategy):
"""Discovery strategy to find M patterns on 15min BTC"""

text
def __init__(self, config):
    super().__init__(config)
    self.bars = []
    self.patterns = []
    self.m_pattern_count = 0

def on_start(self):
    """Called when strategy starts"""
    # Subscribe to 15min bars
    bar_type = BarType(
        self.instrument_id,
        BarAggregation.MINUTE,
        15,
    )
    self.subscribe_bars(bar_type)
    self.log.info(f"M Pattern Discovery started for {self.instrument}")

def on_bar(self, bar: Bar) -> None:
    """Called on each 15min bar"""
    
    # Store bar for pattern detection
    self.bars.append(bar)
    
    # Keep only last 3 bars for memory efficiency
    if len(self.bars) > 3:
        self.bars.pop(0)
    
    # Check for M pattern (only when we have 3+ bars)
    if len(self.bars) >= 3:
        if self.is_m_pattern():
            self.m_pattern_count += 1
            self.patterns.append({
                'timestamp': bar.ts_event,
                'price': float(bar.close),
                'high': float(bar.high),
                'low': float(bar.low),
                'pattern_id': self.m_pattern_count,
            })
            self.log.info(f"M Pattern #{self.m_pattern_count} found at {bar.ts_event}")

def is_m_pattern(self) -> bool:
    """
    Detect M pattern: Down-Up-Down
    bar > bar (down)
    bar < bar (up)
    Next bar would complete the pattern
    """
    if len(self.bars) < 3:
        return False
    
    bar_0_close = float(self.bars.close)
    bar_1_close = float(self.bars.close)
    bar_2_close = float(self.bars.close)
    
    # Down-Up-Down pattern
    down_1 = bar_0_close > bar_1_close
    up = bar_1_close < bar_2_close
    
    return down_1 and up

def on_end(self):
    """Called when backtest ends"""
    self.log.info(f"Discovery complete: Found {self.m_pattern_count} M patterns")
    
    # Save results
    df = pd.DataFrame(self.patterns)
    if len(df) > 0:
        df.to_csv('m_patterns_found.csv', index=False)
        self.log.info(f"Results saved to m_patterns_found.csv")
    
    # Print summary
    print("\\n" + "="*60)
    print("M PATTERN DISCOVERY RESULTS")
    print("="*60)
    print(f"Total M Patterns Found: {self.m_pattern_count}")
    if len(df) > 0:
        print(f"First Pattern: {df.iloc['timestamp']}")
        print(f"Last Pattern: {df.iloc[-1]['timestamp']}")
        print(f"Patterns per day: {len(df) / 90:.2f}")
    print("="*60)
'''

============================================================================
DATA VALIDATION (ALWAYS DO THIS)
============================================================================
DATA_VALIDATION = """
def validate_ohlcv_data(df):
'''Validate data before using'''

text
# Check for missing values
assert not df.isnull().any().any(), "Contains NaN values"

# Check OHLC logic
assert (df['high'] >= df['low']).all(), "High < Low error"
assert (df['open'] <= df['high']).all(), "Open > High error"
assert (df['close'] <= df['high']).all(), "Close > High error"

# Check volume
assert (df['volume'] > 0).all(), "Zero volume found"

# Check time continuity
time_diffs = df.index.to_series().diff()
expected_diff = pd.Timedelta(minutes=15)
gaps = time_diffs[time_diffs > expected_diff * 2]
if len(gaps) > 0:
    print(f"Warning: {len(gaps)} time gaps found")

print(f"✓ Data validation passed")
return True
"""

