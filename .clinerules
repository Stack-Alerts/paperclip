RISK_MANAGEMENT = """
MAX_POSITION_SIZE: 1.0 BTC
MIN_POSITION_SIZE: 0.001 BTC
STOP_LOSS_PERCENT: 2.0% below entry
DAILY_LOSS_LIMIT: $500
MAX_LEVERAGE: 1.0 (no margin)

ENFORCEMENT PATTERN:

# 1. Check position sizing
if quantity > Quantity(self.MAX_POSITION_SIZE):
    self.log.error(f"Position {quantity} exceeds {self.MAX_POSITION_SIZE}")
    return

# 2. Check daily loss limit
daily_pnl = self.calculate_daily_pnl()
if daily_pnl < -self.DAILY_LOSS_LIMIT:
    self.close_all_positions()
    self.log.warning(f"Daily loss limit hit: {daily_pnl}")
    return

# 3. Place order with stop loss
self.submit_order(buy_order)
self.submit_order(stop_order)

# 4. Log everything
self.log.info(f"Order: {quantity} BTC @ {price}")
"""

