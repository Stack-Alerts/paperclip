[Unit]
Description=Paperclip Impact Gate Scan-Done Worker (5-min polling daemon)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/home/sirrus/miniconda3/bin/python3 /home/sirrus/projects/BTC-Trade-Engine-PaperClip/scripts/run_impact_gate_polling_worker.py
StandardOutput=journal
StandardError=journal
StandardInput=null
Environment=HOME=/home/sirrus
Environment=PATH=/home/sirrus/miniconda3/bin:/usr/local/bin:/usr/bin:/bin:/home/sirrus/.local/bin
EnvironmentFile=/home/sirrus/projects/BTC-Trade-Engine-PaperClip/.env
WorkingDirectory=/home/sirrus/projects/BTC-Trade-Engine-PaperClip

[Install]
WantedBy=default.target
