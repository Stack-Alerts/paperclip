[Unit]
Description=Paperclip Impact Gate Scan-Done Worker
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=python3 /home/sirrus/projects/BTC-Trade-Engine-PaperClip/src/impact_gate/worker.py --poll --retroactive --json-summary --poll-interval 0
StandardOutput=journal
StandardError=journal
Environment=HOME=/home/sirrus
Environment=PATH=/usr/local/bin:/usr/bin:/bin:/home/sirrus/.local/bin
EnvironmentFile=/home/sirrus/projects/BTC-Trade-Engine-PaperClip/.env

[Install]
WantedBy=default.target
