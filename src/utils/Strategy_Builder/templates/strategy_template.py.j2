    def __init__(self, config):
        super().__init__(config)
        
        # Strategy identification
        self.strategy_id = "{{ '%03d'|format(config.strategy_number) }}_{{ config.strategy_name|upper|replace(' ', '_') }}"
        self.strategy_name = "{{ config.strategy_name }}"
        
        # Strategy parameters
        self.min_confluence = {{ config.min_confluence }}
        self.max_bars_held = {{ config.max_bars_held }}
        self.capital_allocation_pct = 10.0
        
        # Risk management
        self.max_leverage = {{ config.max_leverage }}
        self.risk_per_trade_pct = {{ config.risk_per_trade_pct }}
        self.min_risk_reward = {{ config.risk_reward_ratio.split(':')[1] if ':' in config.risk_reward_ratio else '3.0' }}
        
        # Initialize building blocks
        self.blocks = {}
        self._initialize_blocks()
        
        # Data storage
