        # Performance tracking
        self.trades_count = 0
        self.wins = 0
        self.losses = 0
        self.total_confluence_scores = []
        
    def _initialize_blocks(self):
        """Initialize building block detectors"""
        
        # Initialize detector instances
        self.detectors = {
            {% for block in config.blocks %}
            '{{ block.block_name }}_{{ loop.index0 }}': {{ block_class_map[block.block_name] }}(timeframe='15min'),
            {% endfor %}
        }
        
        # Block weights configuration
