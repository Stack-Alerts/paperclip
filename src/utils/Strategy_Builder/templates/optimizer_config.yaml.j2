# Optimizer Configuration for Strategy: {{ config.strategy_name }}
# Strategy Number: {{ '%03d'|format(config.strategy_number) }}
# Category: {{ config.strategy_category.value }}
# Auto-generated by Strategy Builder v1.0
# Date: {{ generation_date }}

strategy:
  name: "{{ config.strategy_name }}"
  number: {{ config.strategy_number }}
  category: "{{ config.strategy_category.value }}"
  side: "{{ config.side if config.side else 'LONG' }}"  # Trade direction: SHORT or LONG
  file: "strategy_{{ '%03d'|format(config.strategy_number) }}_{{ config.strategy_name|lower|replace(' ', '_') }}.py"
  class: "{{ class_name }}"

# Parameter Optimization Ranges
parameters:
  # Confluence threshold
  min_confluence:
    type: "int"
    min: {{ config.min_confluence - 20 }}
    max: {{ config.min_confluence + 20 }}
    step: 5
    default: {{ config.min_confluence }}
  
  # Block weights (optimizable)
  block_weights:
    {% for block in config.blocks %}
    {{ block.block_name }}:
      type: "int"
      min: {{ block.weight_range[0] }}
      max: {{ block.weight_range[1] }}
      step: 5
      default: {{ block.weight }}
      enabled: {{ 'true' if block.enabled else 'false' }}
    {% endfor %}
  
  # Signal roles (TEST_ALL signals will be tested in all configurations)
  signal_permutations:
    {% for block in config.blocks %}
    {% for signal in block.signals %}
    {% if signal.role.value == 'TEST_ALL' %}
    {{ block.block_name }}_{{ signal.signal_name }}:
      roles: ["FILTER", "SIGNAL", "BOOSTER"]
      default: "SIGNAL"
    {% endif %}
    {% endfor %}
    {% endfor %}

# Walk-Forward Test Configuration
walk_forward:
  enabled: true
  
  # Training/testing split
  training_window_days: {{ config.training_window_days }}
  testing_window_days: {{ config.testing_window_days }}
  step_days: 30
  
  # Data settings
  data_file: "data/raw/BTC_USDT_PERP_15m.csv"
  timeframe: "15min"
  minimum_bars: {{ config.max_bars_held }}
  
  # Performance metrics to optimize
  optimization_target: "sharpe_ratio"  # sharpe_ratio, profit_factor, win_rate, net_pnl
  
  # Constraints
  constraints:
    min_trades: 5  # Minimum trades in test period
    max_drawdown_pct: 25.0  # Maximum allowed drawdown
    min_win_rate_pct: 30.0  # Minimum win rate
    min_risk_reward: {{ config.min_risk_reward }}  # Minimum R:R ratio (CRITICAL: 1.2-1.5 for Adaptive SL v2.0 with 0.9% SL)

# Backtest Configuration
backtest:
  # Capital settings
  initial_capital: {{ config.starting_capital }}  # Starting capital from strategy configuration
  capital_allocation_pct: 100.0
  
  # Risk management
  max_leverage: {{ config.max_leverage }}
  risk_per_trade_pct: {{ config.risk_per_trade_pct }}
  max_position_size: 1.0  # BTC
  
  # Fees
  maker_fee_pct: 0.02
  taker_fee_pct: 0.05
  
  # Execution
  slippage_pct: 0.05
  
  # Adaptive SL v2.0 Configuration (from Strategy Builder)
  adaptive_sl:
    enabled: true  # Always enabled for institutional-grade risk management
    volatility_lookback: {{ config.volatility_lookback }}
    volatility_multiplier: {{ config.volatility_multiplier }}
    absolute_min_sl_pct: {{ config.absolute_min_sl_pct }}
    absolute_max_sl_pct: {{ config.absolute_max_sl_pct }}
    use_delayed_sl: {{ 'true' if config.use_delayed_sl else 'false' }}
    delay_bars: {{ config.delay_bars }}
    emergency_sl_pct: {{ config.emergency_sl_pct }}
    use_structure_sl: {{ 'true' if config.use_structure_sl else 'false' }}
    structure_sources: {{ config.structure_sources|tojson }}
  
  # Dynamic TP Configuration (placeholder - will be optimization parameter)
  # The optimizer will test multiple TP configurations
  take_profit_levels:
    - level: 1.5  # 1.5R
      size_pct: 50.0
    - level: 3.0  # 3.0R
      size_pct: 30.0
    - level: 5.0  # 5.0R
      size_pct: 20.0

# Optimization Settings
optimization:
  # Search strategy
  method: "grid_search"  # grid_search, random_search, bayesian
  
  # Grid search settings
  grid_search:
    max_combinations: 500  # Limit total combinations
    parallel_jobs: 4  # Number of parallel backtests
  
  # Random search settings (if using random_search)
  random_search:
    n_iterations: 200
    random_seed: 42
  
  # Bayesian optimization settings (if using bayesian)
  bayesian:
    n_iterations: 100
    n_initial_points: 20
    acquisition_function: "ei"  # Expected Improvement

# Results Configuration
results:
  # Output directory
  output_dir: "optimization_results/strategy_{{ '%03d'|format(config.strategy_number) }}_{{ config.strategy_name|lower|replace(' ', '_') }}"
  
  # Save settings
  save_top_n: 10  # Save top N configurations
  save_equity_curves: true
  save_trade_log: true
  save_detailed_report: true
  
  # Report format
  report_format: "markdown"  # markdown, html, pdf

# Validation Settings
validation:
  # Cross-validation
  enable_cross_validation: true
  n_folds: 5
  
  # Out-of-sample testing
  out_of_sample_pct: 20.0  # Reserve 20% for final validation
  
  # Robustness checks
  robustness_tests:
    - "parameter_sensitivity"
    - "time_period_stability"
    - "market_regime_performance"

# Logging
logging:
  level: "INFO"  # DEBUG, INFO, WARNING, ERROR
  save_logs: true
  log_file: "optimization_results/strategy_{{ '%03d'|format(config.strategy_number) }}/optimization.log"

# Strategy-Specific Notes
notes: |
  Strategy: {{ config.strategy_name }}
  Category: {{ config.strategy_category.value }}
  
  Building Blocks ({{ config.blocks|length }} total):
  {% for block in config.blocks %}
  - {{ block.block_display_name }} (Weight: {{ block.weight }})
    {% for signal in block.signals %}
    * {{ signal.signal_display_name }} [{{ signal.role.value }}]
    {% endfor %}
  {% endfor %}
  
  Expected Frequency: Variable (depends on confluence threshold)
  Risk:Reward Target: {{ config.risk_reward_ratio }}
  
  Auto-generated configuration - review and adjust as needed.
